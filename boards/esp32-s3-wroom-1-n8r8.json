{
    "build": {
      "arduino":{
        "flash_mode": "dio",
        "psram_type": "opi",
        "memory_type": "dio_opi",
        "ldscript": "esp32s3_out.ld",
        "partitions": "partitions.csv"
      },
      "core": "esp32",
      "extra_flags": [
        "-DARDUINO_ESP32S3_DEV",
        "-DBOARD_HAS_PSRAM",
        "-DARDUINO_RUNNING_CORE=1",
        "-DARDUINO_USB_CDC_ON_BOOT=0",
        "-DARDUINO_EVENT_RUNNING_CORE=1"
      ],
      "f_cpu": "240000000L",
      "f_flash": "80000000L",
      "boot_freq": "120000000L",
      "hwids": [
        [
          "0x303A",
          "0x1001"
        ]
      ],
      "mcu": "esp32s3",
      "variant": "esp32s3"
    },
    "connectivity": [
      "wifi",
      "bluetooth"
    ],
    "debug": {
      "default_tool": "esptool",
      "onboard_tools": [
        "esp-builtin"
      ],
      "openocd_target": "esp32s3.cfg"
    },
    "frameworks": [
      "arduino",
      "espidf"
    ],
    "name": "Espressif ESP32-S3-DevKitC-1-N8R8 (8 MB QD, 8MB PSRAM)",
    "upload": {
      "flash_size": "8MB",
      "maximum_ram_size": 327680,
      "maximum_size": 3342336,
      "require_upload_port": true,
      "speed": 460800
    },
    "url": "https://docs.espressif.com/projects/esp-idf/en/latest/esp32s3/hw-reference/esp32s3/user-guide-devkitc-1.html",
    "vendor": "Espressif"
  }
